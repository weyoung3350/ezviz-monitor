# ── 统一通知服务 ──
# 部署时将本段内容合并到 /addon_configs/a0d7b954_appdaemon/apps/apps.yaml
# 敏感信息（webhook、secret、AccessKey、手机号等）只在实际部署文件中填写，不要提交到仓库

notify_service:
  module: notify_service
  class: NotifyService

  # 钉钉自定义机器人（加签模式）
  # webhook 形如 https://oapi.dingtalk.com/robot/send?access_token=xxx
  # secret 形如 SECxxxxxx，用于 HMAC-SHA256 加签
  dingtalk_webhook: "<钉钉机器人 webhook URL>"
  dingtalk_secret: "<钉钉机器人加签 secret>"
  # 图片基础 URL：markdown 图片链接的前缀。
  # ⚠️ 注意：钉钉服务器位于公网，通常无法拉取内网 URL（如 192.168.x.x）。
  # 使用内网地址时钉钉 markdown 文字可以送达，但图片在钉钉客户端会显示"加载失败"。
  # 如需图片真实展示，请改用 Nabu Casa / 外网穿透 / 图床的公网可达 URL。
  dingtalk_image_base_url: "http://192.168.77.253:8123/local/"

  # iOS Companion App 推送（留空则不启用）
  ios_push_service: "<notify 服务名，如 notify.mobile_app_dna_iphone15p>"

  # 静默时段（跨天，在此时段内且 force_sound=false 时 iOS 推送静默送达）
  silent_start: "23:00"
  silent_end: "07:00"

  # 电话通道配置（默认关闭）
  phone_enabled: false
  vms_access_key_id: "<AccessKey ID>"
  vms_access_key_secret: "<AccessKey Secret>"
  vms_called_number: "<被叫号码>"
  vms_tts_code: "<TTS 模板编号>"
  vms_called_show_number: "<显示号码>"


# ── 夜间监护编排器 ──
# 监听 night_guard.door_unlock_trigger 事件，执行完整告警编排流程：
#   1. 总开关 / 时段 / 冷却三重判断（全部通过 HA helper 配置）
#   2. 立即发主告警事件（channel=all，含电话响铃）
#   3. 连续抓拍 + 门状态观察
#   4. 发快照通知事件（channel=[dingtalk, ios_push]）
#   5. 发详情兜底事件（channel=[dingtalk, ios_push]）
#
# 前置条件：
#   - input_boolean.night_guard_enabled（总开关，默认 on）
#   - input_datetime.night_guard_start / night_guard_end（告警时段）
#   - input_datetime.last_night_unlock_alert_at（冷却时间戳）
#   - HA automation 已改造为"仅三元组过滤 + fire night_guard.door_unlock_trigger"
#   - AppDaemon NotifyService 已启用

night_guard_orchestrator:
  module: night_guard_orchestrator
  class: NightGuardOrchestrator

  # 设备实体
  camera_entity: "camera.dian_ti_ting_mainstream"
  door_state_entity: "sensor.xiaomi_cn_1150511669_s20pro_door_state_p_3_1021"

  # 抓拍参数
  snapshot_count: 5
  snapshot_interval_seconds: 5
  snapshot_dir: "/config/www"
  snapshot_filename_template: "night_alert_{timestamp}_{index}.jpg"

  # 冷却（秒）
  cooldown_seconds: 300

  # HA helper 实体（需先在 HA configuration.yaml 中声明）
  helper_enabled: "input_boolean.night_guard_enabled"
  helper_window_start: "input_datetime.night_guard_start"
  helper_window_end: "input_datetime.night_guard_end"
  helper_last_alert: "input_datetime.last_night_unlock_alert_at"

  log_prefix: "[night_guard]"
